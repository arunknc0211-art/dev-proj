-- For 2021 Q1 W02 false fires
-- Check if key-matched record and most-current record are DIFFERENT
SELECT
    L.[NDC],
    L.[Effective_Date]          AS Input_Eff,
    L.[File_Run_Date]           AS Run_DLU,
    F.[DRAPR_ID],
    F.[Effective_Date]          AS DB_Eff,
    F.[Terminate_Date]          AS DB_Term,
    F.[Flip_Ind],
    F.[DLU]                     AS DB_DLU,
    CASE 
        WHEN F.[Effective_Date] = L.[Effective_Date] 
        THEN 'KEY MATCH'
        ELSE 'OTHER RECORD'
    END                         AS RecordType,
    COUNT(F.[DRAPR_ID]) OVER 
        (PARTITION BY L.[NDC])  AS TotalRecordsForNDC
FROM [dbo].[DRAPR_Log]   L
JOIN [dbo].[DRAPR_Final] F
    ON F.[NDC] = L.[NDC]
WHERE L.[Log_Code]       = 'W02'
  AND L.[Source_File]    = 'QUARTERLY'
  AND L.[Terminate_Date] IS NULL
  AND L.[Year]           = 2021
  AND L.[Quarter]        = 1
ORDER BY L.[NDC], F.[Effective_Date]

