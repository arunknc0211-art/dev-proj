-- For W02 false fires, find what the DB term date was
-- AT THE TIME of the run (using DLU of the run to find prior state)
-- Focus on 2021 Q1 false fires only — largest group

-- Step 1: Show W02 false fires with the SOURCE data CMS sent
SELECT
    L.[Year],
    L.[Quarter],
    L.[NDC],
    L.[Effective_Date]          AS Input_Eff,
    L.[Terminate_Date]          AS Input_Term,
    L.[File_Run_Date]           AS Run_DLU,
    -- What did CMS actually send for this NDC in 2021 Q1?
    Q.[Market Date]             AS CMS_Market_Date,
    Q.[Reactivation Date]       AS CMS_Reactiv_Date,
    Q.[Termination Date]        AS CMS_Term_Date,
    Q.[COD Status]
FROM [dbo].[DRAPR_Log] L
JOIN [dbo].[CMS_NDS_Active_Drugs_Quarterly] Q
    ON  LTRIM(RTRIM(Q.[NDC])) = L.[NDC]
    AND Q.[Year]               = L.[Year]
    AND Q.[Quarter]            = L.[Quarter]
    AND Q.[DLU]                = L.[File_Run_Date]
WHERE L.[Log_Code]         = 'W02'
  AND L.[Source_File]      = 'QUARTERLY'
  AND L.[Terminate_Date]   IS NULL
  AND L.[Year]             = 2021
  AND L.[Quarter]          = 1
ORDER BY L.[NDC]

