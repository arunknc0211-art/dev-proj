-- Since no backup exists, verify key fix outcomes directly

-- A. Fix A: Confirm Rule 1.1 updates hit the KEY-matched record,
--    not the most-current record.
--    Check: for NDCs with multiple records, 
--    the most-current record's DLU should reflect only the run
--    that matched ITS effective date, not earlier runs.
SELECT
    F.[NDC],
    F.[Effective_Date],
    F.[Terminate_Date],
    F.[Flip_Ind],
    F.[Flip_Sequence],
    F.[DLU],
    COUNT(*) OVER (PARTITION BY F.[NDC]) AS RecordCount
FROM [dbo].[DRAPR_Final] F
WHERE F.[Flip_Ind] = 'N'
  AND EXISTS (
      SELECT 1 FROM [dbo].[DRAPR_Final] F2
      WHERE F2.[NDC] = F.[NDC]
        AND F2.[Flip_Ind] = 'Y'
  )
ORDER BY F.[NDC], F.[Effective_Date]

