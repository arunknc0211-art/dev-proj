WHERE [Log_Code] = 'E13'

-- Step 2: Which NDCs appear most frequently in E13?
SELECT [NDC], COUNT(*) AS QuarterCount,
       MIN([Year] * 10 + [Quarter]) AS FirstOccurrence,
       MAX([Year] * 10 + [Quarter]) AS LastOccurrence
FROM [dbo].[DRAPR_Log]
WHERE [Log_Code] = 'E13'
GROUP BY [NDC]
ORDER BY QuarterCount DESC

-- Step 3: For the top repeating E13 NDC, show what CMS sent vs DB
-- (replace NDC value after running Step 2)
