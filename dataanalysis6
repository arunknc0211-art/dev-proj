-- Confirm: are these W02 fires where DB term was ALSO null before update?
-- (i.e., no real change happened)
SELECT
    L.[Year],
    L.[Quarter],
    L.[NDC],
    L.[Effective_Date]   AS Input_Eff,
    L.[Terminate_Date]   AS Input_Term,   -- This is NULL
    F.[Effective_Date]   AS DB_Eff,
    F.[Terminate_Date]   AS DB_Term,      -- Is this also NULL?
    F.[DLU]              AS DB_DLU,
    F.[Flip_Ind]
FROM [dbo].[DRAPR_Log]   L
JOIN [dbo].[DRAPR_Final] F
    ON  F.[NDC]            = L.[NDC]
    AND F.[Effective_Date] = L.[Effective_Date]
WHERE L.[Log_Code]       = 'W02'
  AND L.[Terminate_Date] IS NULL
  AND L.[Year]           = 2014   -- start with earliest
  AND L.[Quarter]        = 4
ORDER BY L.[NDC]

-- Count: how many W02 with NULL term have DB term also NULL?
SELECT
    CASE WHEN F.[Terminate_Date] IS NULL THEN 'DB_TERM_ALSO_NULL'
         ELSE 'DB_TERM_WAS_SET'
    END                  AS Scenario,
    COUNT(*)             AS Cnt
FROM [dbo].[DRAPR_Log]   L
JOIN [dbo].[DRAPR_Final] F
    ON  F.[NDC]            = L.[NDC]
    AND F.[Effective_Date] = L.[Effective_Date]
WHERE L.[Log_Code]       = 'W02'
  AND L.[Terminate_Date] IS NULL
GROUP BY
    CASE WHEN F.[Terminate_Date] IS NULL THEN 'DB_TERM_ALSO_NULL'
         ELSE 'DB_TERM_WAS_SET'
    END



